{
  "name": "plico",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check": "pnpm lint && pnpm test && pnpm build",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json}": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "^26.0.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "8.1.1",
    "vitest": "^4.1.9"
  }
}
